<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" debug="false">

    <!--
        Production-friendly logging configuration that writes:
         - Human-friendly logs to the console (for local dev)
         - Structured JSON logs to a rolling file (for ship/ingest into ELK/Loki)

        Correlation id (MDC key 'correlationId') is included in both outputs.
    -->

    <property name="LOG_PATH" value="${LOG_PATH:-./logs}" />
    <property name="LOG_FILE" value="${LOG_FILE:-transactionservice}" />

    <!-- Console appender: human readable -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - [%X{correlationId}] %msg%n</pattern>
        </encoder>
    </appender>

    <!-- JSON file appender using Logstash encoder
         Moved under a springProfile named 'json' so it is only parsed/activated when the
         'json' profile is active. This avoids startup failure when the Logstash encoder
         dependency is not available locally. To enable JSON file logging, run with
         -Dspring.profiles.active=json or set SPRING_PROFILES_ACTIVE=json.
    -->

    <springProfile name="json">
        <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_PATH}/${LOG_FILE}.json</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <!-- daily rollover -->
                <fileNamePattern>${LOG_PATH}/${LOG_FILE}.%d{yyyy-MM-dd}.json.gz</fileNamePattern>
                <maxHistory>30</maxHistory>
            </rollingPolicy>

            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <customFields>{"app":"transactionservice","env":"local"}</customFields>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="JSON_FILE" />
        </root>
    </springProfile>

    <!-- Default root logger: console only (safe when JSON encoder not on classpath) -->
    <springProfile name="!json">
        <!-- In local profile write both to console and to a plain text file so actuator /logfile can expose it -->
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_PATH}/${LOG_FILE}.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <fileNamePattern>${LOG_PATH}/${LOG_FILE}.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
                <maxHistory>7</maxHistory>
            </rollingPolicy>
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - [%X{correlationId}] %msg%n</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="FILE" />
        </root>
    </springProfile>

</configuration>

